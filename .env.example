# ============================================================
# .env.example — Variables d'environnement du projet
# ============================================================
# Copiez ce fichier en ".env" et adaptez les valeurs à votre machine.
# Le fichier .env ne doit jamais être commité (ajouté dans .gitignore).
# ============================================================

# --- Device GPU / CPU ---
# "auto"  → GPU si disponible, sinon CPU (défaut)
# "cuda"  → Force le GPU (erreur si CUDA absent)
# "cpu"   → Force le CPU (même si un GPU est présent)
DEVICE_TYPE=auto

# --- MLflow ---
# MLFLOW_TRACKING_URI=sqlite:///mlflow.db
# MLFLOW_EXPERIMENT_NAME=home_credit_default_risk

# --- Modèle ---
RANDOM_STATE=42
TEST_SIZE=0.2
N_FOLDS=5

# --- Colonnes ---
TARGET_COL=TARGET
ID_COL=SK_ID_CURR

# --- Logging ---
# Niveaux disponibles : DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
